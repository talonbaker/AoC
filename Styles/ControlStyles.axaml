<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════════
         TAB STRIP  —  full-width pill buttons (UniformGrid ItemsPanel)
         ════════════════════════════════════════════════════════════════════ -->
    <Style Selector="TabItem">
        <Setter Property="Padding"                    Value="8,8"/>
        <Setter Property="FontSize"                   Value="13"/>
        <Setter Property="FontFamily"                 Value="Inter,Segoe UI,Sans-Serif"/>
        <Setter Property="Foreground"                 Value="{DynamicResource TextMuted}"/>
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="Margin"                     Value="2,0"/>
        <Setter Property="CornerRadius"               Value="6"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="MinHeight"                  Value="36"/>
    </Style>

    <Style Selector="TabItem:selected">
        <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Background"  Value="{DynamicResource Surface}"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
    </Style>

    <!-- Hide FluentTheme underline indicator -->
    <Style Selector="TabItem /template/ Border#PART_SelectedPipe">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         VALUE BOX  —  Border wrapping a transparent TextBox
         ════════════════════════════════════════════════════════════════════ -->
    <Style Selector="Border.value-box">
        <Setter Property="Background"      Value="{DynamicResource Surface}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="4"/>
        <Setter Property="MinWidth"        Value="72"/>
        <Setter Property="Height"          Value="28"/>
    </Style>

    <Style Selector="Border.value-box TextBox">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="Foreground"                 Value="{DynamicResource TextPrimary}"/>
        <Setter Property="CaretBrush"                 Value="{DynamicResource TextPrimary}"/>
        <Setter Property="SelectionBrush"             Value="{DynamicResource Accent}"/>
        <Setter Property="FontFamily"                 Value="Consolas,Courier New,Monospace"/>
        <Setter Property="FontSize"                   Value="12"/>
        <Setter Property="Padding"                    Value="4,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
    </Style>

    <!-- Suppress FluentTheme's own template border so our outer Border is the only chrome -->
    <Style Selector="Border.value-box TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Border.value-box TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Border.value-box TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Border.value-box TextBox:focus-within /template/ Border#PART_BorderElement">
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <!-- Accent ring on the outer Border when its TextBox is focused -->
    <Style Selector="Border.value-box:focus-within">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         LOCK TOGGLE BUTTON
         ════════════════════════════════════════════════════════════════════ -->
    <Style Selector="ToggleButton.lock-btn">
        <Setter Property="Background"      Value="{DynamicResource Surface}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="4"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextSecondary}"/>
        <Setter Property="Padding"         Value="6,4"/>
        <Setter Property="Height"          Value="28"/>
    </Style>

    <Style Selector="ToggleButton.lock-btn:checked">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
        <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
    </Style>

    <Style Selector="ToggleButton.lock-btn:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentDark}"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         PRESET BUTTONS  (2 large, equal-width)
         ════════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.action-btn">
        <Setter Property="Background"               Value="{DynamicResource Surface}"/>
        <Setter Property="BorderBrush"              Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="CornerRadius"             Value="4"/>
        <Setter Property="Foreground"               Value="{DynamicResource TextPrimary}"/>
        <Setter Property="HorizontalAlignment"      Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Padding"                  Value="4,6"/>
        <Setter Property="FontFamily"               Value="Inter,Segoe UI,Sans-Serif"/>
        <Setter Property="FontSize"                 Value="11"/>
    </Style>

    <Style Selector="Button.action-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A3A3A"/>
    </Style>

    <Style Selector="Button.action-btn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#1B2B4F"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         ICON BUTTONS  (4 small utility buttons)
         ════════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.icon-btn">
        <Setter Property="Background"               Value="{DynamicResource Surface}"/>
        <Setter Property="BorderBrush"              Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="CornerRadius"             Value="4"/>
        <Setter Property="Foreground"               Value="{DynamicResource TextSecondary}"/>
        <Setter Property="HorizontalAlignment"      Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Padding"                  Value="2,4"/>
        <Setter Property="Height"                   Value="28"/>
    </Style>

    <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A3A3A"/>
    </Style>

    <Style Selector="Button.icon-btn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#1B2B4F"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         AXIS LABELS
         ════════════════════════════════════════════════════════════════════ -->
    <Style Selector="TextBlock.axis-label">
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        <Setter Property="FontFamily" Value="Inter,Segoe UI,Sans-Serif"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         SLIDERS  —  accent colour on the filled (value) track
         ════════════════════════════════════════════════════════════════════ -->
    <Style Selector="Slider">
        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         CONTAINER HEADER BUTTON
         Transparent button used for the expand/collapse header row of
         ExpandableContainerView.  Provides hover and press feedback without
         the FluentTheme's default chrome (border, background).
         ════════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.container-header-btn">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.container-header-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#26FFFFFF"/>
    </Style>

    <Style Selector="Button.container-header-btn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#3675FF22"/>
    </Style>

</Styles>
