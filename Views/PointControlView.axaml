<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SquareClickerPointer.ViewModels"
             x:Class="SquareClickerPointer.Views.PointControlView"
             x:DataType="vm:PointControlViewModel"
             Width="300"
             Height="700">

    <UserControl.Styles>

        <!-- Tab strip: bordered-box look -->
        <Style Selector="TabItem">
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#888888"/>
            <Setter Property="BorderBrush"     Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin"          Value="2,0"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground"      Value="#1133CC"/>
            <Setter Property="BorderBrush"     Value="#1133CC"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>

        <!-- Outer blue border on the editable value boxes -->
        <Style Selector="Border.value-box">
            <Setter Property="BorderBrush"     Value="#1133CC"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="MinWidth"        Value="70"/>
        </Style>

        <!-- TextBox inside the value-box border — transparent so only the outer border shows -->
        <Style Selector="Border.value-box TextBox">
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Padding"                  Value="6,3"/>
            <Setter Property="FontFamily"               Value="Consolas"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>

        <!-- Stretch + centre the three action buttons -->
        <Style Selector="Button.action-btn">
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                    Value="4,4"/>
        </Style>

    </UserControl.Styles>

    <!-- Outer frame -->
    <Border BorderBrush="#1133CC" BorderThickness="2" Margin="4">

        <TabControl TabStripPlacement="Top" Padding="0,4,0,0">

            <!-- ══════════════════════════════════════════════════════════════
                 TAB 1 — SQUARE  (interactive canvas)
                 ══════════════════════════════════════════════════════════════ -->
            <TabItem Header="square">
                <StackPanel Margin="10" Spacing="8">

                    <!-- ── Editable X / lock-toggle / Y row ── -->
                    <Grid ColumnDefinitions="*,Auto,*">

                        <Border Grid.Column="0" Classes="value-box">
                            <!-- ReflectionBinding needed for UpdateSourceTrigger=LostFocus
                                 (Avalonia compiled bindings do not support that option). -->
                            <TextBox Text="{ReflectionBinding XText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     KeyDown="OnValueBoxKeyDown"
                                     ToolTip.Tip="Type an X value (0 – 10) then press Enter or Tab"/>
                        </Border>

                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                      Margin="8,0"
                                      Padding="6,2"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="Lock X / Y together">
                            <TextBlock FontSize="11" Text="⛓"/>
                        </ToggleButton>

                        <Border Grid.Column="2" Classes="value-box">
                            <TextBox Text="{ReflectionBinding YText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     KeyDown="OnValueBoxKeyDown"
                                     ToolTip.Tip="Type a Y value (0 – 10) then press Enter or Tab"/>
                        </Border>

                    </Grid>

                    <!-- Labels -->
                    <Grid ColumnDefinitions="*,Auto,*">
                        <TextBlock Grid.Column="0" Text="x-val"
                                   HorizontalAlignment="Center"
                                   FontSize="10" Foreground="#666666"/>
                        <TextBlock Grid.Column="2" Text="y-val"
                                   HorizontalAlignment="Center"
                                   FontSize="10" Foreground="#666666"/>
                    </Grid>

                    <!-- ── Interactive canvas ── -->
                    <Border BorderBrush="Black" BorderThickness="2"
                            HorizontalAlignment="Center">
                        <Canvas Width="260" Height="260"
                                Background="White"
                                Cursor="Cross"
                                PointerPressed="OnCanvasPointerPressed"
                                PointerMoved="OnCanvasPointerMoved"
                                PointerReleased="OnCanvasPointerReleased">

                            <!-- Vertical dashed line — tracks X -->
                            <Line StartPoint="{ReflectionBinding VerticalLineStart}"
                                  EndPoint="{ReflectionBinding VerticalLineEnd}"
                                  Stroke="#888888"
                                  StrokeDashArray="5,3"
                                  StrokeThickness="1"/>

                            <!-- Horizontal dashed line — tracks Y -->
                            <Line StartPoint="{ReflectionBinding HorizontalLineStart}"
                                  EndPoint="{ReflectionBinding HorizontalLineEnd}"
                                  Stroke="#888888"
                                  StrokeDashArray="5,3"
                                  StrokeThickness="1"/>

                            <!-- Draggable dot -->
                            <Ellipse Width="16" Height="16"
                                     Fill="#1133CC"
                                     Canvas.Left="{Binding CanvasDotX}"
                                     Canvas.Top="{Binding CanvasDotY}"/>

                        </Canvas>
                    </Border>

                    <!-- ── Preset buttons ── -->
                    <Grid ColumnDefinitions="*,6,*,6,*">

                        <Button Grid.Column="0" Classes="action-btn"
                                Command="{Binding ApplyPresetCommand}"
                                CommandParameter="{Binding Preset1}"
                                ToolTip.Tip="{Binding Preset1.Description}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Preset1.Label}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Preset1.Description}"
                                           HorizontalAlignment="Center"
                                           FontSize="9"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" Classes="action-btn"
                                Command="{Binding ApplyPresetCommand}"
                                CommandParameter="{Binding Preset2}"
                                ToolTip.Tip="{Binding Preset2.Description}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Preset2.Label}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Preset2.Description}"
                                           HorizontalAlignment="Center"
                                           FontSize="9"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" Classes="action-btn"
                                Command="{Binding ApplyPresetCommand}"
                                CommandParameter="{Binding Preset3}"
                                ToolTip.Tip="{Binding Preset3.Description}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Preset3.Label}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Preset3.Description}"
                                           HorizontalAlignment="Center"
                                           FontSize="9"/>
                            </StackPanel>
                        </Button>

                    </Grid>

                </StackPanel>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════
                 TAB 2 — SLIDE  (sliders + aspect-ratio lock)
                 ══════════════════════════════════════════════════════════════ -->
            <TabItem Header="slide">
                <StackPanel Margin="10" Spacing="10">

                    <!-- ── X slider + editable value box ── -->
                    <Grid ColumnDefinitions="*,8,90">
                        <Slider Grid.Column="0"
                                Minimum="0" Maximum="10"
                                Value="{Binding X, Mode=TwoWay}"
                                VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Classes="value-box">
                            <TextBox Text="{ReflectionBinding XText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     KeyDown="OnValueBoxKeyDown"
                                     ToolTip.Tip="Type an X value (0 – 10) then press Enter or Tab"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="x-val"
                               HorizontalAlignment="Left"
                               FontSize="10" Foreground="#666666"
                               Margin="0,-6,0,0"/>

                    <!-- ── Aspect-ratio lock ── -->
                    <ToggleButton IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                  HorizontalAlignment="Left"
                                  Padding="8,3"
                                  ToolTip.Tip="Lock X / Y values together">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="⛓" FontSize="11"/>
                            <TextBlock Text="lock" FontSize="11"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- ── Y slider + editable value box ── -->
                    <Grid ColumnDefinitions="*,8,90">
                        <Slider Grid.Column="0"
                                Minimum="0" Maximum="10"
                                Value="{Binding Y, Mode=TwoWay}"
                                VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Classes="value-box">
                            <TextBox Text="{ReflectionBinding YText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     KeyDown="OnValueBoxKeyDown"
                                     ToolTip.Tip="Type a Y value (0 – 10) then press Enter or Tab"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="y-val"
                               HorizontalAlignment="Left"
                               FontSize="10" Foreground="#666666"
                               Margin="0,-6,0,0"/>

                    <!-- ── Preset buttons ── -->
                    <Grid ColumnDefinitions="*,6,*,6,*" Margin="0,8,0,0">

                        <Button Grid.Column="0" Classes="action-btn"
                                Command="{Binding ApplyPresetCommand}"
                                CommandParameter="{Binding Preset1}"
                                ToolTip.Tip="{Binding Preset1.Description}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Preset1.Label}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Preset1.Description}"
                                           HorizontalAlignment="Center"
                                           FontSize="9"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" Classes="action-btn"
                                Command="{Binding ApplyPresetCommand}"
                                CommandParameter="{Binding Preset2}"
                                ToolTip.Tip="{Binding Preset2.Description}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Preset2.Label}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Preset2.Description}"
                                           HorizontalAlignment="Center"
                                           FontSize="9"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" Classes="action-btn"
                                Command="{Binding ApplyPresetCommand}"
                                CommandParameter="{Binding Preset3}"
                                ToolTip.Tip="{Binding Preset3.Description}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Preset3.Label}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Preset3.Description}"
                                           HorizontalAlignment="Center"
                                           FontSize="9"/>
                            </StackPanel>
                        </Button>

                    </Grid>

                </StackPanel>
            </TabItem>

        </TabControl>
    </Border>

</UserControl>
