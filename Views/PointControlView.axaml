<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SquareClickerPointer.ViewModels"
             x:Class="SquareClickerPointer.Views.PointControlView"
             x:DataType="vm:PointControlViewModel"
             Width="240">

    <Border Background="{StaticResource AppBackground}"
            CornerRadius="8"
            ClipToBounds="True">

        <TabControl TabStripPlacement="Top"
                    Background="Transparent"
                    Padding="0">

            <!-- Full-width equal-width tab buttons -->
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" Margin="8,8,8,0"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>

            <!-- ══════════════════════════════════════════════════════════════
                 TAB 1 — 2D PAD  (interactive canvas)
                 ══════════════════════════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <!-- 3×3 grid icon -->
                        <Viewbox Width="13" Height="13">
                            <UniformGrid Rows="3" Columns="3" Width="15" Height="15">
                                <Rectangle Margin="1" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Margin="1" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Margin="1" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Margin="1" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Margin="1" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Margin="1" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Margin="1" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Margin="1" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Margin="1" Fill="White" RadiusX="1" RadiusY="1"/>
                            </UniformGrid>
                        </Viewbox>
                        <TextBlock Text="2D Pad" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>

                <DockPanel LastChildFill="True">
                    <!-- Separator below tab strip -->
                    <Border DockPanel.Dock="Top"
                            Height="1"
                            Background="{StaticResource BorderSubtle}"
                            Margin="0,4,0,0"/>

                    <StackPanel Margin="12,10,12,12" Spacing="8">

                        <!-- ── X / lock / Y row ── -->
                        <Grid ColumnDefinitions="*,Auto,*">
                            <Border Grid.Column="0" Classes="value-box">
                                <TextBox Text="{ReflectionBinding XText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                         KeyDown="OnValueBoxKeyDown"
                                         ToolTip.Tip="X value (0–10). Press Enter or Tab to commit."/>
                            </Border>

                            <ToggleButton Grid.Column="1"
                                          Classes="lock-btn"
                                          IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                          Margin="6,0"
                                          VerticalAlignment="Center"
                                          ToolTip.Tip="Lock X and Y together">
                                <!-- Chain-link icon -->
                                <Viewbox Width="16" Height="10">
                                    <Canvas Width="22" Height="14">
                                        <Ellipse Canvas.Left="1"  Canvas.Top="1" Width="8" Height="8"
                                                 Stroke="White" StrokeThickness="2" Fill="Transparent"/>
                                        <Ellipse Canvas.Left="13" Canvas.Top="5" Width="8" Height="8"
                                                 Stroke="White" StrokeThickness="2" Fill="Transparent"/>
                                        <Line StartPoint="5,9" EndPoint="17,5"
                                              Stroke="{StaticResource AppBackground}" StrokeThickness="2"/>
                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>

                            <Border Grid.Column="2" Classes="value-box">
                                <TextBox Text="{ReflectionBinding YText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                         KeyDown="OnValueBoxKeyDown"
                                         ToolTip.Tip="Y value (0–10). Press Enter or Tab to commit."/>
                            </Border>
                        </Grid>

                        <!-- ── Axis labels ── -->
                        <Grid ColumnDefinitions="*,Auto,*">
                            <TextBlock Grid.Column="0" Text="x-val" Classes="axis-label"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="y-val" Classes="axis-label"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- ── Interactive 2-D pad canvas ── -->
                        <Border BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="4"
                                HorizontalAlignment="Center"
                                ClipToBounds="True">
                            <Canvas x:Name="PadCanvas"
                                    Width="216" Height="216"
                                    Background="#242424"
                                    Cursor="Cross"
                                    PointerPressed="OnCanvasPointerPressed"
                                    PointerMoved="OnCanvasPointerMoved"
                                    PointerReleased="OnCanvasPointerReleased">

                                <!-- Vertical crosshair — tracks X (solid blue) -->
                                <Line StartPoint="{ReflectionBinding VerticalLineStart}"
                                      EndPoint="{ReflectionBinding VerticalLineEnd}"
                                      Stroke="{StaticResource Accent}"
                                      StrokeThickness="1"/>

                                <!-- Horizontal crosshair — tracks Y (solid blue) -->
                                <Line StartPoint="{ReflectionBinding HorizontalLineStart}"
                                      EndPoint="{ReflectionBinding HorizontalLineEnd}"
                                      Stroke="{StaticResource Accent}"
                                      StrokeThickness="1"/>

                                <!-- Draggable dot -->
                                <Ellipse Width="16" Height="16"
                                         Fill="{StaticResource AccentLight}"
                                         Canvas.Left="{Binding CanvasDotX}"
                                         Canvas.Top="{Binding CanvasDotY}"/>

                                <!-- Y axis label + max value (top-left) -->
                                <TextBlock Canvas.Left="5" Canvas.Top="5"
                                           Text="Y" FontSize="9"
                                           Foreground="{StaticResource TextMuted}"
                                           FontFamily="Inter,Segoe UI,Sans-Serif"/>
                                <TextBlock Canvas.Left="5" Canvas.Top="17"
                                           Text="10" FontSize="8"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontFamily="Inter,Segoe UI,Sans-Serif"/>

                                <!-- X axis label + max value (bottom-right) -->
                                <TextBlock Canvas.Left="196" Canvas.Top="200"
                                           Text="X" FontSize="9"
                                           Foreground="{StaticResource TextMuted}"
                                           FontFamily="Inter,Segoe UI,Sans-Serif"/>
                                <TextBlock Canvas.Left="182" Canvas.Top="200"
                                           Text="10" FontSize="8"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontFamily="Inter,Segoe UI,Sans-Serif"/>

                                <!-- Origin label (bottom-left) -->
                                <TextBlock Canvas.Left="5" Canvas.Top="200"
                                           Text="0" FontSize="8"
                                           Foreground="{StaticResource TextMuted}"
                                           FontFamily="Inter,Segoe UI,Sans-Serif"/>

                            </Canvas>
                        </Border>

                        <!-- ── 2 large preset buttons ── -->
                        <Grid ColumnDefinitions="*,8,*">
                            <Button Grid.Column="0" Classes="action-btn"
                                    Command="{Binding ApplyPresetCommand}"
                                    CommandParameter="{Binding Preset1}"
                                    ToolTip.Tip="{Binding Preset1.Description}">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{Binding Preset1.Label}"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{Binding Preset1.Description}"
                                               HorizontalAlignment="Center" FontSize="8"
                                               Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Classes="action-btn"
                                    Command="{Binding ApplyPresetCommand}"
                                    CommandParameter="{Binding Preset2}"
                                    ToolTip.Tip="{Binding Preset2.Description}">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{Binding Preset2.Label}"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{Binding Preset2.Description}"
                                               HorizontalAlignment="Center" FontSize="8"
                                               Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- ── 4 small icon utility buttons ── -->
                        <Grid ColumnDefinitions="*,6,*,6,*,6,*">

                            <!-- Reset to centre -->
                            <Button Grid.Column="0" Classes="icon-btn"
                                    Command="{Binding GoToCenterCommand}"
                                    ToolTip.Tip="Reset to centre (5, 5)">
                                <TextBlock Text="↺" FontSize="15"/>
                            </Button>

                            <!-- Go to maximum (10, 10) -->
                            <Button Grid.Column="2" Classes="icon-btn"
                                    Command="{Binding GoToMaxCommand}"
                                    ToolTip.Tip="Set both axes to maximum (10, 10)">
                                <!-- Expand icon: 4 corner arrows -->
                                <Viewbox Width="13" Height="13">
                                    <Canvas Width="16" Height="16">
                                        <Line StartPoint="0,5"  EndPoint="0,0"  Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="0,0"  EndPoint="5,0"  Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="11,0" EndPoint="16,0" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="16,0" EndPoint="16,5" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="0,11" EndPoint="0,16" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="0,16" EndPoint="5,16" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="16,11" EndPoint="16,16" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="16,16" EndPoint="11,16" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- Max X -->
                            <Button Grid.Column="4" Classes="icon-btn"
                                    Command="{Binding GoToMaxXCommand}"
                                    ToolTip.Tip="Set X to maximum (10)">
                                <Viewbox Width="15" Height="10">
                                    <Canvas Width="20" Height="14">
                                        <Line StartPoint="0,7"  EndPoint="20,7" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="1,3"  EndPoint="1,11" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="19,3" EndPoint="19,11" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- Max Y -->
                            <Button Grid.Column="6" Classes="icon-btn"
                                    Command="{Binding GoToMaxYCommand}"
                                    ToolTip.Tip="Set Y to maximum (10)">
                                <Viewbox Width="10" Height="15">
                                    <Canvas Width="14" Height="20">
                                        <Line StartPoint="7,0"  EndPoint="7,20" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="3,1"  EndPoint="11,1" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="3,19" EndPoint="11,19" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                        </Grid>

                    </StackPanel>
                </DockPanel>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════
                 TAB 2 — SLIDERS
                 ══════════════════════════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <!-- Sliders icon: two horizontal lines with circle handles -->
                        <Viewbox Width="16" Height="10">
                            <Canvas Width="22" Height="14">
                                <Line StartPoint="0,3.5"  EndPoint="7.5,3.5"  Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                <Ellipse Canvas.Left="7"  Canvas.Top="1"   Width="5" Height="5" Stroke="White" StrokeThickness="1.5"/>
                                <Line StartPoint="12.5,3.5" EndPoint="22,3.5" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                <Line StartPoint="0,10.5" EndPoint="14.5,10.5" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                <Ellipse Canvas.Left="14" Canvas.Top="8"   Width="5" Height="5" Stroke="White" StrokeThickness="1.5"/>
                                <Line StartPoint="19.5,10.5" EndPoint="22,10.5" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Sliders" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>

                <DockPanel LastChildFill="True">
                    <!-- Separator below tab strip -->
                    <Border DockPanel.Dock="Top"
                            Height="1"
                            Background="{StaticResource BorderSubtle}"
                            Margin="0,4,0,0"/>

                    <StackPanel Margin="12,10,12,12" Spacing="8">

                        <!-- ── X: label + value row ── -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="x-val" Classes="axis-label"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Classes="value-box" Width="72">
                                <TextBox Text="{ReflectionBinding XText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                         KeyDown="OnValueBoxKeyDown"
                                         ToolTip.Tip="X value (0–10). Press Enter or Tab to commit."/>
                            </Border>
                        </Grid>

                        <!-- ── X full-width slider ── -->
                        <Slider Minimum="0" Maximum="10"
                                Value="{Binding X, Mode=TwoWay}"/>

                        <!-- ── Lock toggle ── -->
                        <ToggleButton Classes="lock-btn"
                                      IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      ToolTip.Tip="Lock X and Y together">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Viewbox Width="16" Height="10">
                                    <Canvas Width="22" Height="14">
                                        <Ellipse Canvas.Left="1"  Canvas.Top="1" Width="8" Height="8"
                                                 Stroke="White" StrokeThickness="2" Fill="Transparent"/>
                                        <Ellipse Canvas.Left="13" Canvas.Top="5" Width="8" Height="8"
                                                 Stroke="White" StrokeThickness="2" Fill="Transparent"/>
                                        <Line StartPoint="5,9" EndPoint="17,5"
                                              Stroke="{StaticResource AppBackground}" StrokeThickness="2"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="lock" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>

                        <!-- ── Y: label + value row ── -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="y-val" Classes="axis-label"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Classes="value-box" Width="72">
                                <TextBox Text="{ReflectionBinding YText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                         KeyDown="OnValueBoxKeyDown"
                                         ToolTip.Tip="Y value (0–10). Press Enter or Tab to commit."/>
                            </Border>
                        </Grid>

                        <!-- ── Y full-width slider ── -->
                        <Slider Minimum="0" Maximum="10"
                                Value="{Binding Y, Mode=TwoWay}"/>

                        <!-- ── 2 large preset buttons ── -->
                        <Grid ColumnDefinitions="*,8,*" Margin="0,4,0,0">
                            <Button Grid.Column="0" Classes="action-btn"
                                    Command="{Binding ApplyPresetCommand}"
                                    CommandParameter="{Binding Preset1}"
                                    ToolTip.Tip="{Binding Preset1.Description}">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{Binding Preset1.Label}"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{Binding Preset1.Description}"
                                               HorizontalAlignment="Center" FontSize="8"
                                               Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Classes="action-btn"
                                    Command="{Binding ApplyPresetCommand}"
                                    CommandParameter="{Binding Preset2}"
                                    ToolTip.Tip="{Binding Preset2.Description}">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{Binding Preset2.Label}"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{Binding Preset2.Description}"
                                               HorizontalAlignment="Center" FontSize="8"
                                               Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- ── 4 small icon utility buttons ── -->
                        <Grid ColumnDefinitions="*,6,*,6,*,6,*">

                            <Button Grid.Column="0" Classes="icon-btn"
                                    Command="{Binding GoToCenterCommand}"
                                    ToolTip.Tip="Reset to centre (5, 5)">
                                <TextBlock Text="↺" FontSize="15"/>
                            </Button>

                            <Button Grid.Column="2" Classes="icon-btn"
                                    Command="{Binding GoToMaxCommand}"
                                    ToolTip.Tip="Set both axes to maximum (10, 10)">
                                <Viewbox Width="13" Height="13">
                                    <Canvas Width="16" Height="16">
                                        <Line StartPoint="0,5"  EndPoint="0,0"  Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="0,0"  EndPoint="5,0"  Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="11,0" EndPoint="16,0" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="16,0" EndPoint="16,5" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="0,11" EndPoint="0,16" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="0,16" EndPoint="5,16" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="16,11" EndPoint="16,16" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="16,16" EndPoint="11,16" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Button Grid.Column="4" Classes="icon-btn"
                                    Command="{Binding GoToMaxXCommand}"
                                    ToolTip.Tip="Set X to maximum (10)">
                                <Viewbox Width="15" Height="10">
                                    <Canvas Width="20" Height="14">
                                        <Line StartPoint="0,7"  EndPoint="20,7" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="1,3"  EndPoint="1,11" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="19,3" EndPoint="19,11" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Button Grid.Column="6" Classes="icon-btn"
                                    Command="{Binding GoToMaxYCommand}"
                                    ToolTip.Tip="Set Y to maximum (10)">
                                <Viewbox Width="10" Height="15">
                                    <Canvas Width="14" Height="20">
                                        <Line StartPoint="7,0"  EndPoint="7,20" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="3,1"  EndPoint="11,1" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                        <Line StartPoint="3,19" EndPoint="11,19" Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                        </Grid>

                    </StackPanel>
                </DockPanel>
            </TabItem>

        </TabControl>
    </Border>

</UserControl>
