<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SquareClickerPointer.ViewModels"
             x:Class="SquareClickerPointer.Views.ListItemView"
             x:DataType="vm:ListItemViewModel">

    <!--
    ═══════════════════════════════════════════════════════════════════════════════
     ListItemView  —  one row in the expandable list
    ═══════════════════════════════════════════════════════════════════════════════

     WHAT THIS VIEW DOES
     ────────────────────
     Renders a single ListItemViewModel as a horizontal row:

         [Lock toggle] [Name]  [Shape icon]          [ID] [Color square]

     WHAT THIS VIEW DOES NOT DO
     ───────────────────────────
     • It does not set its own DataContext.  The ItemsControl in ItemListView.axaml
       instantiates one ListItemView per item and automatically sets its DataContext
       to the corresponding ListItemViewModel from the FilteredItems collection.

     • It contains no C# logic.  Every dynamic value (lock state, name, shape,
       color) is expressed as a data-binding.  The code-behind (ListItemView.axaml.cs)
       is nearly empty.

     X:DATATYPE
     ───────────
     x:DataType="vm:ListItemViewModel" tells the Avalonia compiler what type the
     DataContext will be at runtime.  This enables COMPILED bindings — the compiler
     checks that "IsLocked", "IsStar", "ColorBrush" etc. actually exist on
     ListItemViewModel at BUILD time, not at runtime.  Typos in binding paths
     become build errors instead of silent failures.
    -->

    <!-- Row container — fixed height keeps all rows the same size in the list -->
    <Border Padding="6,3" Background="Transparent">

        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
              VerticalAlignment="Center">

            <!-- ── Column 0: Lock toggle ──────────────────────────────────────────
                 ToggleButton — a button that stays in its toggled state until
                 pressed again.  It exposes an IsChecked property.

                 IsChecked="{Binding IsLocked, Mode=TwoWay}":
                   TwoWay binding means the binding flows BOTH directions:
                     • When the VM's IsLocked changes → IsChecked updates (View ← VM).
                     • When the user clicks the button → IsChecked flips →
                       the binding writes back to IsLocked on the VM (View → VM).
                   This single binding replaces what used to require an event handler
                   and a manual property assignment.

                 After the write-back, the VM's generated IsLocked setter fires
                 OnIsLockedChanged() → publishes ItemLockToggledMessage over the bus.
                 The View does not know about the message; it only knows about
                 the binding.
            -->
            <ToggleButton Grid.Column="0"
                          IsChecked="{Binding IsLocked, Mode=TwoWay}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="2"
                          Width="26"
                          Height="26"
                          VerticalAlignment="Center"
                          ToolTip.Tip="Toggle lock">

                <!-- Panel stacks both icons on top of each other; only one is
                     visible at a time.  IsVisible="{Binding IsLocked}" and
                     IsVisible="{Binding !IsLocked}" are compiled bool bindings —
                     Avalonia supports the ! prefix for negation. -->
                <Panel Width="12" Height="14">

                    <!-- LOCKED icon (visible when IsLocked = true) -->
                    <Panel IsVisible="{Binding IsLocked}">
                        <!-- Shackle closed — both arms reach the body -->
                        <Path Data="M 3,7 L 3,4 Q 3,0.5 6,0.5 Q 9,0.5 9,4 L 9,7"
                              Stroke="{DynamicResource Accent}"
                              StrokeThickness="1.5"
                              StrokeLineCap="Round"
                              Fill="Transparent"/>
                        <!-- Padlock body rectangle -->
                        <Path Data="M 1,7 L 11,7 L 11,14 L 1,14 Z"
                              Fill="{DynamicResource Accent}"/>
                    </Panel>

                    <!-- UNLOCKED icon (visible when IsLocked = false) -->
                    <Panel IsVisible="{Binding !IsLocked}">
                        <!-- Shackle open — right arm lifted out of body -->
                        <Path Data="M 3,7 L 3,4 Q 3,0.5 6,0.5 Q 9,0.5 9,4 L 9,2"
                              Stroke="{DynamicResource TextMuted}"
                              StrokeThickness="1.5"
                              StrokeLineCap="Round"
                              Fill="Transparent"/>
                        <!-- Padlock body (muted color = unlocked) -->
                        <Path Data="M 1,7 L 11,7 L 11,14 L 1,14 Z"
                              Fill="{DynamicResource TextMuted}"/>
                    </Panel>

                </Panel>
            </ToggleButton>

            <!-- ── Column 1: Item name ────────────────────────────────────────────
                 Simple text label from the model.  Foreground uses TextPrimary
                 from the app's palette (defined in App.axaml ResourceDictionary).
                 Margin="4,0" gives a small gap between the lock and the name.
            -->
            <TextBlock Grid.Column="1"
                       Text="{Binding Name}"
                       Foreground="{DynamicResource TextPrimary}"
                       FontFamily="Inter,Segoe UI,Sans-Serif"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="4,0"/>

            <!-- ── Column 2: Shape icon (16 × 16) ────────────────────────────────
                 A Canvas with a fixed 16×16 size.  All four shapes are defined as
                 Path children, but at most one is visible at a time — controlled
                 by the IsStar / IsHexagon / IsTriangle / IsSquare bool properties
                 on the ViewModel (computed from the ShapeType enum value).

                 WHY Canvas instead of Grid or StackPanel?
                   Canvas has a fixed size regardless of its children's sizes.
                   Invisible children in a Grid still occupy their cell — Canvas
                   children are always at (0,0) and the Canvas itself always
                   reports its Width/Height to the parent layout.

                 WHY Path geometries instead of images or icons?
                   Paths scale to any DPI without blurring, are pure XAML with no
                   external file dependencies, and their Fill color can be data-bound
                   to ColorBrush — giving each item its own unique colour.

                 PATH GEOMETRY STRINGS (SVG-compatible syntax):
                   M x,y  — Move to (x,y) without drawing
                   L x,y  — Line to (x,y)
                   Q cx,cy x,y — Quadratic Bezier curve
                   Z      — Close the path (line back to M start point)

                 All shapes use a 16×16 coordinate space so they fit the Canvas.
            -->
            <Canvas Grid.Column="2"
                    Width="16" Height="16"
                    Margin="4,0"
                    VerticalAlignment="Center">

                <!-- STAR — 5-pointed, outer radius 7, inner radius 3 -->
                <Path Canvas.Left="0" Canvas.Top="0"
                      Data="M 8,1 L 9.76,5.57 L 14.66,5.84 L 10.85,8.93 L 12.11,13.66 L 8,11 L 3.89,13.66 L 5.15,8.93 L 1.34,5.84 L 6.24,5.57 Z"
                      Fill="{Binding ColorBrush}"
                      IsVisible="{Binding IsStar}"/>

                <!-- HEXAGON — pointy-top, radius 7 -->
                <Path Canvas.Left="0" Canvas.Top="0"
                      Data="M 8,1 L 14.06,4.5 L 14.06,11.5 L 8,15 L 1.94,11.5 L 1.94,4.5 Z"
                      Fill="{Binding ColorBrush}"
                      IsVisible="{Binding IsHexagon}"/>

                <!-- TRIANGLE — pointing up -->
                <Path Canvas.Left="0" Canvas.Top="0"
                      Data="M 8,1 L 15,15 L 1,15 Z"
                      Fill="{Binding ColorBrush}"
                      IsVisible="{Binding IsTriangle}"/>

                <!-- SQUARE — inset 2px from edge -->
                <Path Canvas.Left="0" Canvas.Top="0"
                      Data="M 2,2 L 14,2 L 14,14 L 2,14 Z"
                      Fill="{Binding ColorBrush}"
                      IsVisible="{Binding IsSquare}"/>

            </Canvas>

            <!-- ── Column 3: ID number ────────────────────────────────────────────
                 The item's unique integer identifier.  Shown as muted text between
                 the shape icon and the status square, as described in the spec.
                 Width="32" reserves enough room for 3-digit IDs without shifting.
            -->
            <TextBlock Grid.Column="3"
                       Text="{Binding Id}"
                       Foreground="{DynamicResource TextMuted}"
                       FontFamily="Consolas,Courier New,Monospace"
                       FontSize="10"
                       Width="32"
                       TextAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="6,0,4,0"/>

            <!-- ── Column 4: Status / color square ───────────────────────────────
                 A solid rectangle whose Fill matches the item's ColorBrush —
                 the same brush used to fill the shape icon in Column 2.
                 This creates the visual link between the shape and the status
                 indicator: both always show the same colour.
            -->
            <Rectangle Grid.Column="4"
                        Width="14" Height="14"
                        Fill="{Binding ColorBrush}"
                        VerticalAlignment="Center"
                        RadiusX="2" RadiusY="2"/>

        </Grid>
    </Border>

</UserControl>
