<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SquareClickerPointer.ViewModels"
             x:Class="SquareClickerPointer.Views.ListItemView"
             x:DataType="vm:ListItemViewModel">

    <!--
    ═══════════════════════════════════════════════════════════════════════════════
     ListItemView  —  one row in the expandable list, with shape and colour pickers
    ═══════════════════════════════════════════════════════════════════════════════

     ROW LAYOUT (left → right)
     ──────────────────────────
       [Lock toggle]  [Name]  [Shape (clickable)]  [ID]  [Colour square (clickable)]

     PICKER PATTERN — same for both colour and shape
     ──────────────────────────────────────────────────
       1. The clickable element is wrapped in a ToggleButton.
          IsChecked is bound TwoWay to IsColorPickerOpen / IsShapePickerOpen on the VM.
          Clicking the button toggles the property → opens or closes the Popup.

       2. A Popup is placed as a sibling of the ToggleButton inside a Panel.
          Popup.IsOpen is also bound TwoWay to the same VM property.
          When the ViewModel sets IsColorPickerOpen=false (after a swatch is selected),
          the Popup closes automatically via the binding.

       3. IsLightDismissEnabled=True on the Popup means clicking anywhere OUTSIDE
          the picker also closes it.  When the Popup closes this way, Popup.IsOpen
          is set to false, which writes back through the TwoWay binding →
          IsColorPickerOpen becomes false → ToggleButton.IsChecked becomes false.
          Everything stays in sync through bindings alone.

       4. Inside the Popup, an ItemsControl renders the swatch collection.
          Each swatch button binds Command={Binding PickCommand} which is a
          RelayCommand pre-wired (in the constructor) to call SelectColor/SelectShape
          with a specific value.  No CommandParameter needed.
    -->

    <Border Padding="6,3" Background="Transparent">

        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
              VerticalAlignment="Center">

            <!-- ── Column 0: Lock toggle ──────────────────────────────────────────
                 IsChecked="{Binding IsLocked, Mode=TwoWay}":
                   Button click → IsChecked flips → TwoWay binding writes IsLocked
                   → OnIsLockedChanged hook fires → raises ItemLockEventBus.ItemLockToggled.
            -->
            <ToggleButton Grid.Column="0"
                          IsChecked="{Binding IsLocked, Mode=TwoWay}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="2"
                          Width="26" Height="26"
                          VerticalAlignment="Center"
                          ToolTip.Tip="Toggle lock">
                <Panel Width="12" Height="14">

                    <!-- LOCKED icon -->
                    <Panel IsVisible="{Binding IsLocked}">
                        <Path Data="M 3,7 L 3,4 Q 3,0.5 6,0.5 Q 9,0.5 9,4 L 9,7"
                              Stroke="{DynamicResource Accent}"
                              StrokeThickness="1.5" StrokeLineCap="Round" Fill="Transparent"/>
                        <Path Data="M 1,7 L 11,7 L 11,14 L 1,14 Z"
                              Fill="{DynamicResource Accent}"/>
                    </Panel>

                    <!-- UNLOCKED icon -->
                    <Panel IsVisible="{Binding !IsLocked}">
                        <Path Data="M 3,7 L 3,4 Q 3,0.5 6,0.5 Q 9,0.5 9,4 L 9,2"
                              Stroke="{DynamicResource TextMuted}"
                              StrokeThickness="1.5" StrokeLineCap="Round" Fill="Transparent"/>
                        <Path Data="M 1,7 L 11,7 L 11,14 L 1,14 Z"
                              Fill="{DynamicResource TextMuted}"/>
                    </Panel>

                </Panel>
            </ToggleButton>

            <!-- ── Column 1: Item name ─────────────────────────────────────────── -->
            <TextBlock Grid.Column="1"
                       Text="{Binding Name}"
                       Foreground="{DynamicResource TextPrimary}"
                       FontFamily="Inter,Segoe UI,Sans-Serif"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="4,0"/>

            <!-- ── Column 2: Shape icon (clickable → opens shape picker) ──────────
                 The shape icon is wrapped in a ToggleButton so it is keyboard-
                 accessible and provides hover/press feedback.
                 IsChecked ↔ IsShapePickerOpen (TwoWay) drives the Popup.
            -->
            <Panel Grid.Column="2"
                   Margin="4,0"
                   VerticalAlignment="Center">

                <!-- Clickable shape area — ToggleButton acts as the anchor -->
                <ToggleButton x:Name="ShapePickerAnchor"
                              IsChecked="{Binding IsShapePickerOpen, Mode=TwoWay}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="2"
                              Width="22" Height="22"
                              VerticalAlignment="Center"
                              ToolTip.Tip="Change shape">

                    <!-- Shape canvas — same geometry as in the row, but inside the button -->
                    <Canvas Width="16" Height="16">
                        <Path Canvas.Left="0" Canvas.Top="0"
                              Data="M 8,1 L 9.76,5.57 L 14.66,5.84 L 10.85,8.93 L 12.11,13.66 L 8,11 L 3.89,13.66 L 5.15,8.93 L 1.34,5.84 L 6.24,5.57 Z"
                              Fill="{Binding ColorBrush}" IsVisible="{Binding IsStar}"/>
                        <Path Canvas.Left="0" Canvas.Top="0"
                              Data="M 8,1 L 14.06,4.5 L 14.06,11.5 L 8,15 L 1.94,11.5 L 1.94,4.5 Z"
                              Fill="{Binding ColorBrush}" IsVisible="{Binding IsHexagon}"/>
                        <Path Canvas.Left="0" Canvas.Top="0"
                              Data="M 8,1 L 15,15 L 1,15 Z"
                              Fill="{Binding ColorBrush}" IsVisible="{Binding IsTriangle}"/>
                        <Path Canvas.Left="0" Canvas.Top="0"
                              Data="M 2,2 L 14,2 L 14,14 L 2,14 Z"
                              Fill="{Binding ColorBrush}" IsVisible="{Binding IsSquare}"/>
                    </Canvas>

                </ToggleButton>

                <!-- ── SHAPE PICKER POPUP ────────────────────────────────────────
                     PlacementTarget ties the popup's position to the ToggleButton above.
                     IsOpen ↔ IsShapePickerOpen (TwoWay):
                       • Opening: user clicks ShapePickerAnchor → IsChecked flips →
                         IsShapePickerOpen = true → this Popup opens.
                       • Closing via selection: SelectShape() sets IsShapePickerOpen=false
                         → Popup.IsOpen becomes false via binding.
                       • Closing via light-dismiss: user clicks elsewhere → Popup.IsOpen
                         becomes false → TwoWay binding writes IsShapePickerOpen=false
                         → IsChecked becomes false.
                -->
                <Popup IsOpen="{Binding IsShapePickerOpen, Mode=TwoWay}"
                       PlacementTarget="{Binding #ShapePickerAnchor}"
                       Placement="Bottom"
                       IsLightDismissEnabled="True">

                    <Border Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderMedium}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="6">

                        <!--
                        ── SHAPE PICKER GRID
                        2 × 2 grid of shape tiles using a WrapPanel capped at 2 columns.
                        Each tile shows the shape icon at 40×40 in TextPrimary colour
                        on a SurfaceDeep background.  The item's current colour is NOT
                        shown here — the picker selects WHICH SHAPE, not how it looks
                        in context.  Colour is chosen separately in the colour picker.

                        ItemsSource={Binding ShapePaletteItems}:
                          DataContext here is ListItemViewModel (inherited from the
                          ListItemView UserControl).  The Popup inherits the same
                          DataContext from its logical parent (the Panel inside
                          the UserControl).

                        x:DataType on the DataTemplate:
                          Tells the compiled-binding system that each DataTemplate
                          instance's DataContext will be ShapeSwatchViewModel.
                        -->
                        <ItemsControl ItemsSource="{Binding ShapePaletteItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <!-- MaxWidth = 2 tiles × (56 + 6 margin) = 124px -->
                                    <WrapPanel Orientation="Horizontal" MaxWidth="130"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ShapeSwatchViewModel">

                                    <Button Command="{Binding PickCommand}"
                                            Width="54" Height="50"
                                            Margin="3"
                                            Padding="8"
                                            Background="{DynamicResource SurfaceDeep}"
                                            BorderBrush="{DynamicResource BorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            ToolTip.Tip="{Binding Shape}">

                                        <!-- Shape paths — same geometry as the row icon, scaled up -->
                                        <Viewbox Width="32" Height="32" Stretch="Uniform">
                                            <Canvas Width="16" Height="16">
                                                <Path Canvas.Left="0" Canvas.Top="0"
                                                      Data="M 8,1 L 9.76,5.57 L 14.66,5.84 L 10.85,8.93 L 12.11,13.66 L 8,11 L 3.89,13.66 L 5.15,8.93 L 1.34,5.84 L 6.24,5.57 Z"
                                                      Fill="{DynamicResource TextPrimary}"
                                                      IsVisible="{Binding IsStar}"/>
                                                <Path Canvas.Left="0" Canvas.Top="0"
                                                      Data="M 8,1 L 14.06,4.5 L 14.06,11.5 L 8,15 L 1.94,11.5 L 1.94,4.5 Z"
                                                      Fill="{DynamicResource TextPrimary}"
                                                      IsVisible="{Binding IsHexagon}"/>
                                                <Path Canvas.Left="0" Canvas.Top="0"
                                                      Data="M 8,1 L 15,15 L 1,15 Z"
                                                      Fill="{DynamicResource TextPrimary}"
                                                      IsVisible="{Binding IsTriangle}"/>
                                                <Path Canvas.Left="0" Canvas.Top="0"
                                                      Data="M 2,2 L 14,2 L 14,14 L 2,14 Z"
                                                      Fill="{DynamicResource TextPrimary}"
                                                      IsVisible="{Binding IsSquare}"/>
                                            </Canvas>
                                        </Viewbox>

                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Popup>
            </Panel>

            <!-- ── Column 3: ID number ────────────────────────────────────────────── -->
            <TextBlock Grid.Column="3"
                       Text="{Binding Id}"
                       Foreground="{DynamicResource TextMuted}"
                       FontFamily="Consolas,Courier New,Monospace"
                       FontSize="10"
                       Width="32"
                       TextAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="6,0,4,0"/>

            <!-- ── Column 4: Colour square (clickable → opens colour picker) ──────
                 Same ToggleButton + Popup pattern as the shape picker above.
                 The small coloured rectangle inside the button IS the visual that
                 the user sees and clicks.  Its Fill binds to ColorBrush — when the
                 user picks a new colour, ColorBrush updates and the square refreshes.
            -->
            <Panel Grid.Column="4"
                   VerticalAlignment="Center">

                <ToggleButton x:Name="ColorPickerAnchor"
                              IsChecked="{Binding IsColorPickerOpen, Mode=TwoWay}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="1"
                              Width="20" Height="20"
                              VerticalAlignment="Center"
                              ToolTip.Tip="Change colour">

                    <!-- The visual colour square -->
                    <Rectangle Width="14" Height="14"
                               Fill="{Binding ColorBrush}"
                               RadiusX="2" RadiusY="2"/>

                </ToggleButton>

                <!-- ── COLOUR PICKER POPUP ───────────────────────────────────────
                     4 × 3 grid of colour tiles matching the design spec image.
                     Same open/close mechanism as the shape picker above.
                -->
                <Popup IsOpen="{Binding IsColorPickerOpen, Mode=TwoWay}"
                       PlacementTarget="{Binding #ColorPickerAnchor}"
                       Placement="Bottom"
                       IsLightDismissEnabled="True">

                    <Border Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderMedium}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="6">

                        <!--
                        ── COLOUR PICKER GRID
                        12 tiles in a 4-column WrapPanel = 3 rows.
                        Each tile is a plain coloured button — Background={Binding Brush}
                        with no text or icon inside.  The colour IS the content.

                        Sizes chosen to match the proportions shown in the design image:
                          Tile: 50 × 44 + 4px margin → 4 columns = 216px + 12px padding
                        -->
                        <ItemsControl ItemsSource="{Binding ColorPaletteItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" MaxWidth="228"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ColorSwatchViewModel">

                                    <!--
                                    Background="{Binding Brush}":
                                      Each swatch's background IS its colour.
                                      This is the same brush stored on ColorSwatchViewModel.

                                    Command="{Binding PickCommand}":
                                      Pre-wired RelayCommand that calls SelectColor(thisColor)
                                      on the parent ListItemViewModel — no CommandParameter.
                                    -->
                                    <Button Command="{Binding PickCommand}"
                                            Width="50" Height="44"
                                            Margin="3"
                                            Padding="0"
                                            BorderThickness="0"
                                            CornerRadius="3"
                                            Background="{Binding Brush}"/>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Popup>
            </Panel>

        </Grid>
    </Border>

</UserControl>
